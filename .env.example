# ─────────────────────────────────────────────────────────────
#  xais-brain — Variables d'environnement
# ─────────────────────────────────────────────────────────────
#  Copie ce fichier en .env et remplis les clés que tu utilises.
#  Un seul provider suffit — choisis celui que tu préfères via
#  LLM_PROVIDER ci-dessous.
# ─────────────────────────────────────────────────────────────

# Quel LLM utiliser pour traiter tes fichiers (file-intel) ?
# Valeurs acceptées : gemini | claude | openai
LLM_PROVIDER=gemini

# ── Google Gemini (gratuit, recommandé pour démarrer) ────────
# https://aistudio.google.com/apikey
GOOGLE_API_KEY=

# ── Anthropic Claude (payant, qualité supérieure) ────────────
# https://console.anthropic.com/
ANTHROPIC_API_KEY=

# ── OpenAI (payant) ──────────────────────────────────────────
# https://platform.openai.com/api-keys
OPENAI_API_KEY=
